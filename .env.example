# --- Core ---
SECRET_KEY=replace-with-a-long-random-string
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"

# SQLite (default, right for local/family use):
DATABASE_URL=sqlite:///finfamily.db
FLASK_DEBUG=0
PORT=8000

# --- Gmail statement ingestion (optional) ---
# Requires 2-Step Verification on your Google account, then create an
# App Password: Google Account > Security > 2-Step Verification > App passwords.
# The app connects read-only over IMAP and never modifies your mailbox.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# How far back to search, in days:
GMAIL_SEARCH_DAYS=90
# Extra sender domains/addresses beyond the built-in Indian bank + CAMS/KFintech list:
# GMAIL_SENDERS=mybank.example.com,statements@other.com

# --- CAS (CAMS/KFintech consolidated MF statement) ---
# Password you set when requesting the CAS (commonly your PAN, uppercase):
CAS_PASSWORD=
