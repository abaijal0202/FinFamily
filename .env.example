SECRET_KEY=replace-with-a-long-random-string
# SQLite (default, good for demo/small deployments):
DATABASE_URL=sqlite:///finfamily.db
# Or PostgreSQL (recommended for production - see DEPLOY_GCP.md):
# DATABASE_URL=postgresql://finfamily_user:password@localhost:5432/finfamily
FLASK_DEBUG=0
PORT=5000
